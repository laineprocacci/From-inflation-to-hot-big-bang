       RowBox[{"x", "[", "nu", "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"alpha", ",", "0", ",", "3"}], "}"}]}], "]"}], "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"gamma", "[", 
       RowBox[{"beta", ",", "mu", ",", "nu"}], "]"}], 
      RowBox[{"gamma", "[", 
       RowBox[{"alpha", ",", "beta", ",", "alpha"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"alpha", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"beta", ",", "0", ",", "3"}], "}"}]}], "]"}], "-", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"gamma", "[", 
       RowBox[{"beta", ",", "mu", ",", "alpha"}], "]"}], 
      RowBox[{"gamma", "[", 
       RowBox[{"alpha", ",", "beta", ",", "nu"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"alpha", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"beta", ",", "0", ",", "3"}], "}"}]}], "]"}]}]}]], "Input",
