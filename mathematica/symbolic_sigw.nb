Cell[BoxData[
 RowBox[{
  RowBox[{"riccidown", "[", 
   RowBox[{"mu_", ",", "nu_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"gamma", "[", 
        RowBox[{"alpha", ",", "mu", ",", "nu"}], "]"}], ",", 
       RowBox[{"x", "[", "alpha", "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"alpha", ",", "0", ",", "3"}], "}"}]}], "]"}], "-", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"gamma", "[", 
