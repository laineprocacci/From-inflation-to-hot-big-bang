Cell[BoxData[
 RowBox[{
  RowBox[{"gamma", "[", 
   RowBox[{"rho_", ",", "mu_", ",", "nu_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"1", "/", "2"}], " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"gup", "[", 
       RowBox[{"rho", ",", "sigma"}], "]"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"gdown", "[", 
           RowBox[{"sigma", ",", "mu"}], "]"}], ",", 
          RowBox[{"x", "[", "nu", "]"}]}], "]"}], "+", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"gdown", "[", 
           RowBox[{"sigma", ",", "nu"}], "]"}], ",", 
          RowBox[{"x", "[", "mu", "]"}]}], "]"}], "-", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"gdown", "[", 
           RowBox[{"mu", ",", "nu"}], "]"}], ",", 
          RowBox[{"x", "[", "sigma", "]"}]}], "]"}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"sigma", ",", "0", ",", "3"}], "}"}]}], "]"}]}]}]], "Input",
